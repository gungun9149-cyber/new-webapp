rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Allow each authenticated user to read/write only their own document and logs
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;

      match /logs/{logId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
    }
  }
}
